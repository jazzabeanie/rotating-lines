#!/usr/bin/env bash
set -e

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

if ! git diff --cached --name-only | grep -qE '^(src/|wscript|package.json)'; then
  exit 0
fi

if [ -z "$CONDA_DEFAULT_ENV" ]; then
  source "$(conda info --base)/etc/profile.d/conda.sh"
  conda activate "$repo_root/conda-env"
fi

timeout 60 pebble build
timeout 60 pebble install --emulator basalt \
  || { pebble kill; timeout 60 pebble install --emulator basalt; } \
  || { pebble kill; pebble wipe; timeout 60 pebble install --emulator basalt; }

mkdir -p screenshots
timeout 60 bash -c '
  for i in $(seq 1 15); do
    pebble screenshot --emulator basalt "screenshots/basalt-$(printf "%02d" $i).png" || exit 1
    [ "$i" -lt 15 ] && sleep 1
  done
' || echo "screenshot loop exceeded 60s, continuing"

git add screenshots/basalt-*.png 2>/dev/null || true

pebble kill
